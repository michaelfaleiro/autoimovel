@page "/aportes/novo"
@using AutoImovel.Admin.Services
@inject ApiClient Api
@inject NavigationManager Nav

<div class="animate-fade-in">
    <div class="mb-6">
        <a href="/aportes" class="text-sm text-brand-primary-600 dark:text-brand-accent-300 hover:underline font-bold inline-flex items-center gap-2">
            <i class="fa-solid fa-arrow-left"></i> Voltar para Aportes
        </a>
    </div>

    <div class="bg-brand-white dark:bg-black border border-slate-200 dark:border-brand-primary-800 rounded-2xl shadow-sm overflow-hidden max-w-2xl">
        <div class="px-6 py-5 border-b border-slate-200 dark:border-brand-primary-800/20 bg-slate-50/50 dark:bg-brand-primary-900/50">
            <h3 class="font-plus text-lg font-bold text-brand-primary-600 dark:text-brand-white">Registrar Novo Aporte</h3>
            <p class="text-xs text-slate-500 mt-1">Insira os detalhes do investimento recebido para alocação.</p>
        </div>

        <div class="p-6 space-y-5">
            <div>
                <label class="block text-xs font-black uppercase tracking-widest text-slate-500 mb-2">Investidor</label>
                <div class="relative">
                    <span class="absolute inset-y-0 left-0 pl-3.5 flex items-center text-slate-400">
                        <i class="fa-solid fa-user-tie"></i>
                    </span>
                    <div class="pl-10">
                        <AutoComplete Items="@_investidores"
                                      Value="@_investidorId"
                                      ValueChanged="@(v => { _investidorId = v is Guid id ? id : Guid.Empty; })"
                                      DisplayText="@DisplayInvestidor"
                                      SelectedValue="@(i => ((SelectInvestidor)i).Id)"
                                      Placeholder="Digite o nome ou CPF do investidor..." />
                    </div>
                </div>
            </div>

            <div>
                <label class="block text-xs font-black uppercase tracking-widest text-slate-500 mb-2">Valor do Aporte</label>
                <div class="relative">
                    <span class="absolute inset-y-0 left-0 pl-3.5 flex items-center text-slate-400">
                        <i class="fa-solid fa-brazilian-real-sign"></i>
                    </span>
                    <div class="pl-10">
                        <MonetaryInput @bind-Value="@_valor" />
                    </div>
                </div>
                <p class="text-[10px] text-slate-400 mt-1 font-medium"><i class="fa-solid fa-circle-info text-brand-highlight"></i> Aporte mínimo regulatório: R$ 100.000,00</p>
            </div>

            <div>
                <label class="block text-xs font-black uppercase tracking-widest text-slate-500 mb-2">URL do Contrato SCP</label>
                <div class="relative">
                    <span class="absolute inset-y-0 left-0 pl-3.5 flex items-center text-slate-400">
                        <i class="fa-solid fa-link"></i>
                    </span>
                    <input @bind="_urlContrato" type="url"
                            class="w-full bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 rounded-xl pl-10 pr-4 py-3 text-sm text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-brand-accent-600 transition-all"
                           placeholder="https://drive.google.com/..." />
                </div>
            </div>

            @if (!string.IsNullOrEmpty(_msg))
            {
                <div class="p-3.5 rounded-xl text-xs font-bold flex items-center gap-2 @(_erro ? "bg-rose-500/10 border border-rose-500/20 text-rose-500" : "bg-emerald-500/10 border border-emerald-500/20 text-emerald-600 dark:text-emerald-400")">
                    <i class="fa-solid @(_erro ? "fa-circle-exclamation" : "fa-circle-check") text-lg"></i>
                    @_msg
                </div>
            }
        </div>
        <div class="px-6 py-4 border-t border-slate-200 dark:border-brand-primary-800/20 bg-slate-50/50 dark:bg-brand-primary-900/50 flex justify-end">
            <button @onclick="Submit" disabled="@_loading"
                    class="px-6 py-2.5 bg-brand-primary-600 hover:bg-brand-secondary-600 text-brand-white font-bold rounded-xl transition-all shadow-lg shadow-brand-primary-600/20 disabled:opacity-50 flex items-center gap-2">
                @if (_loading)
                {
                    <i class="fa-solid fa-circle-notch animate-spin"></i>
                    <span>Processando...</span>
                }
                else
                {
                    <i class="fa-solid fa-check-double"></i>
                    <span>Registrar Aporte</span>
                }
            </button>
        </div>
    </div>
</div>

@code {
    private List<SelectInvestidor> _investidores = new();
    private Guid _investidorId;
    private decimal _valor;
    private string _urlContrato = string.Empty;
    private bool _loading;
    private string _msg = string.Empty;
    private bool _erro;

    private string DisplayInvestidor(SelectInvestidor i) => $"{i.NomeCompleto} ({i.CpfCnpj})";

    protected override async Task OnInitializedAsync()
    {
        _investidores = await Api.GetInvestidoresSelectAsync("Aprovado");
    }

    private async Task Submit()
    {
        _msg = "";
        _erro = false;

        if (_investidorId == Guid.Empty)
        {
            _msg = "Selecione um investidor válido.";
            _erro = true;
            return;
        }

        if (_valor < 100_000)
        {
            _msg = "Aporte mínimo é R$ 100.000,00.";
            _erro = true;
            return;
        }

        _loading = true;
        try
        {
            var result = await Api.RegistrarAporteAsync(new RegistrarAporteRequest(
                _investidorId, _valor, _urlContrato));
            _msg = $"Aporte registrado com sucesso! ID: {result.Id}";
            // Reset form
            _investidorId = Guid.Empty;
            _valor = 0;
            _urlContrato = string.Empty;
        }
        catch (Exception ex)
        {
            _msg = $"Erro: {ex.Message}";
            _erro = true;
        }
        finally
        {
            _loading = false;
        }
    }
}
