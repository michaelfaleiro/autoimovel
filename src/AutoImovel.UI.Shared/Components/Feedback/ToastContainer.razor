@namespace AutoImovel.UI.Shared.Components.Feedback

<div class="@($"fixed top-4 right-4 z-50 flex flex-col gap-2")">
    @foreach (var toast in Toasts)
    {
        <div class="@($"px-4 py-3 rounded-lg shadow-lg text-white text-sm font-medium animate-slide-in {GetToastClass(toast.Type)}")"
             @onclick="() => RemoveToast(toast.Id)">
            @toast.Message
        </div>
    }
</div>

@code {
    [Parameter] public List<ToastItem> Toasts { get; set; } = new();
    [Parameter] public EventCallback<ToastItem> OnRemove { get; set; }

    private string GetToastClass(string type) => type switch
    {
        "success" => "bg-emerald-600",
        "error" => "bg-rose-600",
        "warning" => "bg-amber-600",
        "info" => "bg-sky-600",
        _ => "bg-slate-600"
    };

    private async Task RemoveToast(string id)
    {
        await OnRemove.InvokeAsync(Toasts.FirstOrDefault(t => t.Id == id));
    }

    public class ToastItem
    {
        public string Id { get; set; } = Guid.NewGuid().ToString();
        public string Message { get; set; } = string.Empty;
        public string Type { get; set; } = "info";
        public DateTime CreatedAt { get; set; } = DateTime.UtcNow;
    }
}
