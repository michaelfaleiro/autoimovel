@namespace AutoImovel.UI.Shared.Components.Layout

<aside class="w-64 bg-slate-900 text-white flex flex-col flex-shrink-0">
    <div class="p-4 border-b border-slate-700">
        <h1 class="text-lg font-bold tracking-tight">AutoImóvel</h1>
    </div>
    <nav class="flex-1 p-3 space-y-1 overflow-y-auto">
        @foreach (var item in Items)
        {
            <a href="@item.Href"
               class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors
                      @(IsActive(item.Href) ? "bg-slate-700 text-white" : "text-slate-300 hover:bg-slate-800 hover:text-white")">
                <span class="w-5 h-5 flex items-center justify-center">
                    @GetIcon(item.Icon)
                </span>
                @item.Label
            </a>
        }
    </nav>
</aside>

@code {
    [Parameter] public List<NavItem> Items { get; set; } = new();

    private bool IsActive(string href) => false; // Will be enhanced with NavigationManager

    private string GetIcon(string name) => name switch
    {
        "home" => "🏠",
        "users" => "👥",
        "wallet" => "💰",
        "truck" => "🚛",
        "link" => "🔗",
        "check-circle" => "✅",
        _ => "📄"
    };

    public class NavItem
    {
        public string Label { get; set; } = string.Empty;
        public string Icon { get; set; } = string.Empty;
        public string Href { get; set; } = string.Empty;
    }
}
