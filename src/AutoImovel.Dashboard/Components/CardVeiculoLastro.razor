@using AutoImovel.Dashboard.Services
@using AutoImovel.Shared.Domain.Enums

<div class="bg-white rounded-lg shadow p-6 hover:shadow-md transition-shadow">
    <div class="flex justify-between items-start mb-3">
        <div>
            <h3 class="font-semibold text-gray-900">@Veiculo.MarcaModelo</h3>
            <p class="text-sm text-gray-500">@Veiculo.AnoFabricacaoModelo</p>
        </div>
        <span class="px-2 py-1 text-xs rounded-full @StatusColor">@Veiculo.StatusVeiculo</span>
    </div>

    <div class="space-y-2 text-sm">
        <div class="flex justify-between">
            <span class="text-gray-500">Placa</span>
            <span class="font-medium text-gray-900">@Veiculo.Placa</span>
        </div>
        <div class="flex justify-between">
            <span class="text-gray-500">Quilometragem</span>
            <span class="font-medium text-gray-900">@Veiculo.Km.ToString("N0") km</span>
        </div>
        <div class="flex justify-between">
            <span class="text-gray-500">Seu Valor Alocado</span>
            <span class="font-semibold text-primary-700">R$ @Veiculo.ValorAlocado.ToString("N2")</span>
        </div>
        <div class="flex justify-between">
            <span class="text-gray-500">Data Alocação</span>
            <span class="text-gray-700">@Veiculo.DataAlocacao.ToString("dd/MM/yyyy")</span>
        </div>
    </div>

    <div class="mt-4 pt-3 border-t">
        <a href="@Veiculo.UrlLaudoCautelar" target="_blank"
            class="text-primary-600 hover:text-primary-800 text-sm font-medium">
            📄 Ver Laudo Cautelar
        </a>
    </div>
</div>

@code {
    [Parameter] public VeiculoLastroItemResponse Veiculo { get; set; } = null!;

    private string StatusColor => Veiculo.StatusVeiculo switch
    {
        StatusVeiculo.Disponivel => "bg-green-100 text-green-800",
        StatusVeiculo.Compra => "bg-yellow-100 text-yellow-800",
        StatusVeiculo.Preparacao => "bg-blue-100 text-blue-800",
        StatusVeiculo.Vendido => "bg-gray-100 text-gray-800",
        _ => "bg-gray-100 text-gray-800"
    };
}
