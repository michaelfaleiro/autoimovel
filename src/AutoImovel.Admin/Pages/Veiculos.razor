@page "/veiculos"
@using AutoImovel.Admin.Services
@using AutoImovel.Shared.Domain.Enums
@inject ApiClient Api
@inject NavigationManager Nav

<div class="animate-fade-in">
    <div class="flex items-center justify-between mb-8">
        <div>
            <h2 class="font-plus text-2xl font-black text-brand-primary-600 dark:text-brand-white">Estoque de Veículos</h2>
            <p class="text-sm text-slate-500 mt-1">Gerenciamento de ativos físicos e controle de preparação.</p>
        </div>
        <a href="/veiculos/cadastrar" class="inline-flex items-center gap-2 px-5 py-2.5 bg-brand-highlight-600 hover:bg-brand-highlightLight text-brand-white text-sm font-bold rounded-xl transition-all shadow-lg shadow-brand-highlight-600/20">
            <i class="fa-solid fa-car-side"></i>
            Cadastrar Veículo
        </a>
    </div>

    <div class="bg-white dark:bg-slate-900 rounded-2xl shadow-sm border border-slate-200 dark:border-slate-800 overflow-hidden">
        <div class="px-6 py-5 border-b border-slate-200 dark:border-slate-800 flex items-center justify-between flex-wrap gap-4 bg-slate-50/50 dark:bg-slate-800/50">
            <div class="flex items-center gap-3">
                <div class="relative">
                    <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-slate-400">
                        <i class="fa-solid fa-magnifying-glass text-xs"></i>
                    </span>
                    <input @bind="_search" @bind:event="oninput"
                           class="border border-slate-300 dark:border-slate-700 rounded-xl pl-9 pr-3 py-2 text-sm bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-brand-accent-600 w-64 transition-all"
                           placeholder="Buscar placa ou modelo..." />
                </div>
                <select @bind="_statusFilter" @bind:after="ApplyFilters"
                        class="border border-slate-300 dark:border-slate-700 rounded-xl px-3 py-2 text-sm bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-brand-accent-600 transition-all">
                    <option value="">Todos os Status</option>
                    <option value="Compra">Compra</option>
                    <option value="Preparacao">Preparação</option>
                    <option value="Disponivel">Disponível</option>
                    <option value="Vendido">Vendido</option>
                </select>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-slate-200 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-800/50">
                        <th class="px-6 py-4 text-left font-bold text-brand-primary-600 dark:text-slate-400 uppercase tracking-wider text-[10px]">Placa</th>
                        <th class="px-6 py-4 text-left font-bold text-brand-primary-600 dark:text-slate-400 uppercase tracking-wider text-[10px]">Modelo / Ano</th>
                        <th class="px-6 py-4 text-left font-bold text-brand-primary-600 dark:text-slate-400 uppercase tracking-wider text-[10px]">Identificação</th>
                        <th class="px-6 py-4 text-right font-bold text-brand-primary-600 dark:text-slate-400 uppercase tracking-wider text-[10px]">Investimento</th>
                        <th class="px-6 py-4 text-left font-bold text-brand-primary-600 dark:text-slate-400 uppercase tracking-wider text-[10px]">Status</th>
                        <th class="px-6 py-4 text-right font-bold text-brand-primary-600 dark:text-slate-400 uppercase tracking-wider text-[10px]">Ações</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                    @if (!_items.Any())
                    {
                        <tr><td colspan="6" class="px-6 py-12 text-center text-slate-400 italic">Nenhum veículo encontrado.</td></tr>
                    }
                    @foreach (var item in _items)
                    {
                        <tr @onclick='() => IrVeiculo(item.Id)' class="group hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors cursor-pointer">
                            <td class="px-6 py-4">
                                <span class="bg-slate-100 dark:bg-slate-800 border border-slate-300 dark:border-slate-700 px-2 py-1 rounded font-bold text-slate-700 dark:text-slate-200 tracking-wider">@item.Placa</span>
                            </td>
                            <td class="px-6 py-4">
                                <p class="font-bold text-slate-800 dark:text-slate-200 group-hover:text-brand-primary-600 dark:group-hover:text-brand-gold transition-colors">@item.MarcaModelo</p>
                                <p class="text-[10px] text-slate-400 font-medium">@item.Cor</p>
                            </td>
                            <td class="px-6 py-4">
                                <p class="text-[10px] text-slate-500 dark:text-slate-400 font-mono">CH: @item.Chassi</p>
                                <p class="text-[10px] text-slate-500 dark:text-slate-400 font-mono">RV: @item.Renavam</p>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <p class="text-sm font-bold text-slate-800 dark:text-slate-200">R$ @item.PrecoCompra.ToString("N2")</p>
                                <p class="text-[10px] text-slate-400 font-medium">@item.Km.ToString("N0") KM</p>
                            </td>
                            <td class="px-6 py-4">
                                <span class="px-3 py-1 text-[10px] font-black uppercase rounded-full @GetColor(item.Status)">
                                    @item.Status.ToString()
                                </span>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex justify-end gap-2">
                                    @if (item.Status == StatusVeiculo.Compra)
                                    {
                                        <button @onclick="() => AvancarStatus(item.Id, StatusVeiculo.Preparacao)" @onclick:stopPropagation
                                                class="px-3 py-1.5 text-[10px] font-black uppercase bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition-all shadow-md shadow-blue-600/10">
                                            Preparar
                                        </button>
                                    }
                                    else if (item.Status == StatusVeiculo.Preparacao)
                                    {
                                        <button @onclick="() => AvancarStatus(item.Id, StatusVeiculo.Disponivel)" @onclick:stopPropagation
                                                class="px-3 py-1.5 text-[10px] font-black uppercase bg-emerald-600 hover:bg-emerald-700 text-white rounded-lg transition-all shadow-md shadow-emerald-600/10">
                                            Liberar
                                        </button>
                                    }
                                    else if (item.Status == StatusVeiculo.Disponivel)
                                    {
                                        <a href="/vincular-lastro?veiculoId=@item.Id" @onclick:stopPropagation
                                            class="px-3 py-1.5 text-[10px] font-black uppercase bg-brand-primary-600 hover:bg-brand-secondary-600 text-brand-white rounded-lg transition-all shadow-md shadow-brand-primary-600/10">
                                            Vincular
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="px-6 py-4 border-t border-slate-200 dark:border-slate-800 flex items-center justify-between bg-slate-50/30 dark:bg-slate-900/50">
            <span class="text-xs font-bold text-slate-400 uppercase tracking-widest">Página @_page de @_totalPages</span>
            <div class="flex gap-2">
                <button class="flex items-center gap-1 px-4 py-2 text-xs font-bold uppercase tracking-widest rounded-xl border transition-all @(_page <= 1 ? "text-slate-300 border-slate-200 cursor-not-allowed" : "text-brand-primary-600 dark:text-brand-gold border-brand-primary-600/20 dark:border-slate-800 hover:bg-brand-primary-600 hover:text-brand-white shadow-lg shadow-brand-primary-600/5")"
                        disabled="@(_page <= 1)" @onclick="() => GoToPage(_page - 1)">
                    <i class="fa-solid fa-chevron-left"></i>
                    Anterior
                </button>
                <button class="flex items-center gap-1 px-4 py-2 text-xs font-bold uppercase tracking-widest rounded-xl border transition-all @(_page >= _totalPages ? "text-slate-300 border-slate-200 cursor-not-allowed" : "text-brand-primary-600 dark:text-brand-gold border-brand-primary-600/20 dark:border-slate-800 hover:bg-brand-primary-600 hover:text-brand-white shadow-lg shadow-brand-primary-600/5")"
                        disabled="@(_page >= _totalPages)" @onclick="() => GoToPage(_page + 1)">
                    Próxima
                    <i class="fa-solid fa-chevron-right"></i>
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private List<VeiculoItem> _items = new();
    private int _page = 1;
    private int _totalPages = 1;
    private string _search = string.Empty;
    private string _statusFilter = string.Empty;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        var result = await Api.GetVeiculosAsync(_page, 20, string.IsNullOrEmpty(_statusFilter) ? null : _statusFilter, string.IsNullOrEmpty(_search) ? null : _search);
        _items = result.Items;
        _totalPages = result.TotalPages > 0 ? result.TotalPages : 1;
    }

    private async Task ApplyFilters()
    {
        _page = 1;
        await LoadData();
    }

    private async Task GoToPage(int page)
    {
        if (page < 1 || page > _totalPages) return;
        _page = page;
        await LoadData();
    }

    private void IrVeiculo(Guid id) => Nav.NavigateTo($"/veiculos/{id}");

    private async Task AvancarStatus(Guid id, StatusVeiculo novoStatus)
    {
        try
        {
            await Api.AtualizarStatusVeiculoAsync(id, novoStatus);
            await LoadData();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Erro ao atualizar status: {ex.Message}");
        }
    }

    private string GetColor(StatusVeiculo status) => status switch
    {
        StatusVeiculo.Compra => "bg-brand-highlight-100/10 text-brand-highlight-600 dark:text-brand-highlight-400 border border-brand-highlight-600/20",
        StatusVeiculo.Preparacao => "bg-brand-primary-100/10 text-brand-primary-600 dark:text-brand-primary-400 border border-brand-primary-600/20",
        StatusVeiculo.Disponivel => "bg-brand-accent-100/10 text-brand-accent-600 dark:text-brand-accent-400 border border-brand-accent-600/20",
        StatusVeiculo.Vendido => "bg-brand-secondary-100/10 text-brand-secondary-600 dark:text-brand-secondary-400 border border-brand-secondary-600/20",
        _ => "bg-slate-100 text-slate-700"
    };
}
