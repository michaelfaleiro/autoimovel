@page "/"
@using Blazored.LocalStorage
@using AutoImovel.Dashboard.Services
@inject ApiClient Api
@inject ILocalStorageService Storage
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject ThemeService Theme

<!-- ===== HEADER ===== -->
<header class="border-b border-slate-200 dark:border-slate-800 bg-white/80 dark:bg-slate-900/80 backdrop-blur-md sticky top-0 z-40 px-4 py-3 md:px-8 transition-colors">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <div class="flex items-center self-center md:self-start space-x-3">
            <img src="/images/logo.png" alt="AutoImóvel Logo" class="h-12 w-auto object-contain" />
            <div class="hidden md:block">
                <div class="flex items-center space-x-2">
                    <span class="text-[10px] uppercase font-bold tracking-widest px-2 py-0.5 rounded bg-brand-gold/10 text-brand-gold border border-brand-gold/20">Investidor</span>
                </div>
            </div>
        </div>

        @if (_patrimonio is not null)
        {
            <div class="flex flex-wrap items-center gap-3 bg-slate-100 dark:bg-slate-800/50 p-2 rounded-2xl border border-slate-200 dark:border-slate-700 self-start md:self-auto">
                <div class="flex items-center space-x-3 px-2">
                    <div class="h-9 w-9 rounded-full bg-slate-200 dark:bg-slate-700 border border-brand-gold/50 flex items-center justify-center font-bold text-brand-gold text-sm">
                        @GetInitials(_patrimonio.NomeInvestidor)
                    </div>
                    <div>
                        <p class="text-xs font-semibold text-slate-800 dark:text-slate-200">@_patrimonio.NomeInvestidor</p>
                        <p class="text-[10px] text-slate-500 dark:text-slate-400">SCP: <span class="font-mono text-brand-gold">SCP-@_codigoSCP</span></p>
                    </div>
                </div>
                <div class="h-6 w-px bg-slate-300 dark:bg-slate-800 hidden sm:block"></div>
                <div class="flex items-center space-x-1.5 bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border border-emerald-500/20 px-3 py-1 rounded-xl text-xs font-medium">
                    <span class="h-2 w-2 rounded-full bg-emerald-400 animate-pulse"></span>
                    <span>SCP ATIVA</span>
                </div>
                <button @onclick="ToggleTheme" class="text-xs bg-slate-200 dark:bg-slate-700 text-slate-600 dark:text-slate-300 hover:bg-slate-300 dark:hover:bg-slate-600 border border-slate-300 dark:border-slate-600 px-3 py-1.5 rounded-xl transition flex items-center space-x-1">
                    <i class="fa-solid @(Theme.IsDark ? "fa-sun" : "fa-moon")"></i>
                    <span>@(Theme.IsDark ? "Claro" : "Escuro")</span>
                </button>
                <button @onclick="Logout" class="text-xs bg-red-500/10 text-red-500 dark:text-red-400 hover:bg-red-500/20 border border-red-500/20 px-3 py-1.5 rounded-xl transition flex items-center space-x-1">
                    <i class="fa-solid fa-right-from-bracket"></i>
                    <span>Sair</span>
                </button>
            </div>
        }
    </div>
</header>

<!-- ===== MAIN CONTENT ===== -->
<main class="flex-grow max-w-7xl w-full mx-auto p-4 md:p-8 flex flex-col gap-6">

    @if (_patrimonio is not null)
    {
        <!-- Hero Block -->
        <div class="bg-gradient-to-r from-slate-100 to-slate-200 dark:from-slate-900 dark:to-slate-800 border border-slate-200 dark:border-slate-800 rounded-3xl p-6 relative overflow-hidden shadow-2xl">
            <div class="absolute -right-10 -bottom-10 w-40 h-40 bg-brand-gold/5 rounded-full blur-2xl"></div>
            <div class="absolute -left-10 -top-10 w-40 h-40 bg-blue-500/5 rounded-full blur-2xl"></div>

            <div class="relative z-10 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
                <div>
                    <h1 class="font-plus text-2xl md:text-3xl font-extrabold text-slate-900 dark:text-white mb-2">Visão Geral da Cota</h1>
                    <p class="text-slate-600 dark:text-slate-400 max-w-2xl text-sm leading-relaxed">
                        Acompanhe em tempo real a alocação do seu capital em ativos físicos seminovos de altíssima liquidez. Toda a segurança do lastro físico com gestão estratégica de liquidez pela administradora.
                    </p>
                </div>
                <div class="flex flex-wrap gap-3">
                    <button @onclick='() => _activeTab = "simulation"' class="bg-brand-highlight-600 hover:bg-brand-highlightLight text-brand-primary-600 font-bold text-xs px-4 py-3 rounded-xl transition duration-200 flex items-center space-x-2 shadow-lg shadow-brand-highlight-600/15">
                        <i class="fa-solid fa-calculator"></i>
                        <span>Simular Reinvestimento</span>
                    </button>
                    <button @onclick='() => _activeTab = "assets"' class="bg-white dark:bg-slate-800 hover:bg-slate-100 dark:hover:bg-slate-700 text-slate-900 dark:text-white font-bold text-xs px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 transition duration-200 flex items-center space-x-2">
                        <i class="fa-solid fa-car"></i>
                        <span>Ver Carros Alocados</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- KPI Cards -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            <div class="bg-white dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 rounded-2xl p-5 hover:border-slate-300 dark:hover:border-slate-700 transition duration-200 shadow-sm dark:shadow-lg">
                <div class="flex items-center justify-between mb-3">
                    <span class="text-xs text-slate-500 dark:text-slate-400 uppercase font-semibold tracking-wider">Patrimônio da Cota</span>
                    <div class="h-8 w-8 rounded-lg bg-blue-500/10 flex items-center justify-center text-blue-600 dark:text-blue-400">
                        <i class="fa-solid fa-wallet text-sm"></i>
                    </div>
                </div>
                <h3 class="font-plus text-2xl font-black text-slate-900 dark:text-white tracking-tight">R$ @_patrimonio.PatrimonioTotal.ToString("N2")</h3>
                <p class="text-xs text-slate-500 dark:text-slate-400 mt-2 flex items-center space-x-1">
                    <span class="text-emerald-600 dark:text-emerald-400 font-bold"><i class="fa-solid fa-circle-check"></i> 1 Cota</span>
                    <span>integralizada na SCP</span>
                </p>
            </div>

            <div class="bg-white dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 rounded-2xl p-5 hover:border-slate-300 dark:hover:border-slate-700 transition duration-200 shadow-sm dark:shadow-lg">
                <div class="flex items-center justify-between mb-3">
                    <span class="text-xs text-slate-500 dark:text-slate-400 uppercase font-semibold tracking-wider">Em Caixa (D+1)</span>
                    <div class="h-8 w-8 rounded-lg bg-emerald-500/10 flex items-center justify-center text-emerald-600 dark:text-emerald-400">
                        <i class="fa-solid fa-circle-dollar-to-slot text-sm"></i>
                    </div>
                </div>
                <h3 class="font-plus text-2xl font-black text-slate-900 dark:text-white tracking-tight">R$ @_patrimonio.CapitalEmLiquidez.ToString("N2")</h3>
                <p class="text-xs text-slate-500 dark:text-slate-400 mt-2 flex items-center space-x-1">
                    <span class="text-emerald-600 dark:text-emerald-400 font-bold"><i class="fa-solid fa-chart-line"></i> Rendendo</span>
                    <span>em conta de liquidez</span>
                </p>
            </div>

            <div class="bg-white dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 rounded-2xl p-5 hover:border-slate-300 dark:hover:border-slate-700 transition duration-200 shadow-sm dark:shadow-lg">
                <div class="flex items-center justify-between mb-3">
                    <span class="text-xs text-slate-500 dark:text-slate-400 uppercase font-semibold tracking-wider">Alocado em Carros</span>
                    <div class="h-8 w-8 rounded-lg bg-brand-highlight-100/10 flex items-center justify-center text-brand-highlight-600">
                        <i class="fa-solid fa-shield-halved text-sm"></i>
                    </div>
                </div>
                <h3 class="font-plus text-2xl font-black text-slate-900 dark:text-white tracking-tight">R$ @_patrimonio.CapitalAlocado.ToString("N2")</h3>
                <p class="text-xs text-slate-500 dark:text-slate-400 mt-2 flex items-center space-x-1">
                    <span class="text-brand-highlight-600 font-bold">100% Lastreado</span>
                    <span>em @_veiculos.Count veículo(s) premium</span>
                </p>
            </div>

            <div class="bg-white dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 rounded-2xl p-5 hover:border-slate-300 dark:hover:border-slate-700 transition duration-200 shadow-sm dark:shadow-lg">
                <div class="flex items-center justify-between mb-3">
                    <span class="text-xs text-slate-500 dark:text-slate-400 uppercase font-semibold tracking-wider">Rendimento Alvo</span>
                    <div class="h-8 w-8 rounded-lg bg-amber-500/10 flex items-center justify-center text-amber-600 dark:text-amber-500">
                        <i class="fa-solid fa-percent text-sm"></i>
                    </div>
                </div>
                <h3 class="font-plus text-2xl font-black text-slate-900 dark:text-white tracking-tight">3,0% a 4,0% <span class="text-xs font-normal text-slate-500 dark:text-slate-400">a.m.</span></h3>
                <p class="text-xs text-slate-500 dark:text-slate-400 mt-2 flex items-center space-x-1">
                    <span class="text-emerald-600 dark:text-emerald-400 font-bold">Líquido</span>
                    <span>Isenção de IR na SCP</span>
                </p>
            </div>
        </div>

        <!-- Tab Navigation -->
        <div class="border-b border-slate-200 dark:border-slate-800/60 flex space-x-1 overflow-x-auto pb-1">
                    <button @onclick='() => _activeTab = "overview"' class="px-5 py-3 text-sm font-semibold whitespace-nowrap transition-all duration-150 @(_activeTab == "overview" ? "border-b-2 border-brand-highlight-600 text-brand-highlight-600" : "border-b-2 border-transparent text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:border-slate-300 dark:hover:border-slate-700")">
                <i class="fa-solid fa-chart-pie mr-2"></i>Distribuição & Fluxo
            </button>
                <button @onclick='() => _activeTab = "assets"' class="px-5 py-3 text-sm font-semibold whitespace-nowrap transition-all duration-150 @(_activeTab == "assets" ? "border-b-2 border-brand-highlight-600 text-brand-highlight-600" : "border-b-2 border-transparent text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:border-slate-300 dark:hover:border-slate-700")">
                <i class="fa-solid fa-car-side mr-2"></i>Estoque Alocado <span class="ml-1 bg-brand-highlight-100/20 text-brand-highlight-600 text-[10px] px-1.5 py-0.5 rounded font-bold">@_veiculos.Count</span>
            </button>
                <button @onclick='() => _activeTab = "simulation"' class="px-5 py-3 text-sm font-semibold whitespace-nowrap transition-all duration-150 @(_activeTab == "simulation" ? "border-b-2 border-brand-highlight-600 text-brand-highlight-600" : "border-b-2 border-transparent text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:border-slate-300 dark:hover:border-slate-700")">
                <i class="fa-solid fa-calculator mr-2"></i>Simulador Composto
            </button>
                <button @onclick='() => _activeTab = "documents"' class="px-5 py-3 text-sm font-semibold whitespace-nowrap transition-all duration-150 @(_activeTab == "documents" ? "border-b-2 border-brand-highlight-600 text-brand-highlight-600" : "border-b-2 border-transparent text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white hover:border-slate-300 dark:hover:border-slate-700")">
                <i class="fa-solid fa-folder-open mr-2"></i>Documentos & Relatórios
            </button>
        </div>

        <!-- ===== TAB: OVERVIEW ===== -->
        @if (_activeTab == "overview")
        {
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 animate-fade-in">
                <div class="lg:col-span-5 bg-white dark:bg-slate-900/30 border border-slate-200 dark:border-slate-800 rounded-3xl p-6 flex flex-col justify-between">
                    <div>
                        <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-1">Status de Alocação de Capital</h3>
                        <p class="text-xs text-slate-500 dark:text-slate-400">Distribuição atual do capital investido de R$ @_patrimonio.PatrimonioTotal.ToString("N2")</p>
                    </div>

                    <div class="my-8 flex flex-col items-center justify-center">
                        <div class="w-full bg-slate-200 dark:bg-slate-800 h-8 rounded-2xl overflow-hidden flex shadow-inner">
                            <div class="bg-gradient-to-r from-blue-600 to-indigo-500 h-full flex items-center justify-center font-bold text-[11px] text-white transition-all duration-500" style="width: @PercentualEmCaixa%">@PercentualEmCaixa%</div>
                            <div class="bg-gradient-to-r from-brand-highlight-600 to-yellow-500 h-full flex items-center justify-center font-bold text-[11px] text-brand-primary-600 transition-all duration-500" style="width: @PercentualAlocado%">@PercentualAlocado%</div>
                        </div>

                        <div class="grid grid-cols-2 gap-4 w-full mt-6">
                            <div class="bg-blue-50 dark:bg-brand-primary-600/60 p-3 rounded-2xl border border-blue-100 dark:border-slate-800">
                                <div class="flex items-center space-x-2 text-blue-600 dark:text-blue-400 mb-1">
                                    <span class="h-3 w-3 rounded-full bg-blue-500"></span>
                                    <span class="text-xs font-semibold">Em Caixa</span>
                                </div>
                                <p class="text-lg font-bold text-slate-900 dark:text-white">R$ @_patrimonio.CapitalEmLiquidez.ToString("N2")</p>
                                <span class="text-[10px] text-slate-500 dark:text-slate-500">Rendimento D+1</span>
                            </div>
                            <div class="bg-amber-50 dark:bg-brand-primary-600/60 p-3 rounded-2xl border border-amber-100 dark:border-slate-800">
                                <div class="flex items-center space-x-2 text-brand-highlight-600 dark:text-brand-highlight-600 mb-1">
                                    <span class="h-3 w-3 rounded-full bg-brand-highlight-600"></span>
                                    <span class="text-xs font-semibold">Alocado</span>
                                </div>
                                <p class="text-lg font-bold text-slate-900 dark:text-white">R$ @_patrimonio.CapitalAlocado.ToString("N2")</p>
                                <span class="text-[10px] text-slate-500 dark:text-slate-500">Lastro Real (Carros)</span>
                            </div>
                        </div>
                    </div>

                    <div class="bg-brand-highlight-600/5 dark:bg-brand-highlight-600/10 border border-brand-highlight-600/20 dark:border-brand-highlight-600/10 p-4 rounded-2xl flex items-start space-x-3">
                        <i class="fa-solid fa-circle-info text-brand-highlight-600 mt-0.5"></i>
                        <p class="text-xs text-slate-600 dark:text-slate-400 leading-relaxed">
                            <strong class="text-brand-highlight-600 font-semibold">Regra de Giro:</strong> Enquanto o capital não é alocado na compra de veículos premium da Garage 345, ele permanece rendendo com liquidez em investimentos conservadores.
                        </p>
                    </div>
                </div>

                <div class="lg:col-span-7 bg-white dark:bg-brand-secondary-500/30 border border-slate-200 dark:border-slate-800 rounded-3xl p-6">
                    <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2">Ciclo de Eficiência do Seu Capital</h3>
                    <p class="text-xs text-slate-500 dark:text-slate-400 mb-6">Como o dinheiro transita de forma blindada de ponta a ponta na operação</p>

                    <div class="relative pl-6 border-l-2 border-slate-200 dark:border-slate-800 space-y-6">
                        <div class="relative">
                            <span class="absolute -left-[31px] top-0.5 bg-blue-600 h-4 w-4 rounded-full border-4 border-slate-200 dark:border-brand-primary-600"></span>
                            <h4 class="text-xs font-bold text-slate-800 dark:text-slate-200 uppercase tracking-wide">1. Formalização Legal (SCP)</h4>
                            <p class="text-xs text-slate-600 dark:text-slate-400 mt-1">Sua cota de R$ @_patrimonio.PatrimonioTotal.ToString("N2") entra de forma protegida e com blindagem jurídica no Fundo via Sociedade em Conta de Participação.</p>
                        </div>
                        <div class="relative">
                            <span class="absolute -left-[31px] top-0.5 bg-indigo-500 h-4 w-4 rounded-full border-4 border-slate-200 dark:border-brand-primary-600"></span>
                            <h4 class="text-xs font-bold text-slate-800 dark:text-slate-200 uppercase tracking-wide">2. Gestão de Caixa & Inteligência de Compra</h4>
                            <p class="text-xs text-slate-600 dark:text-slate-400 mt-1">O time busca oportunidades subavaliadas no mercado de seminovos premium. Capital em caixa rende em liquidez D+1.</p>
                        </div>
                        <div class="relative">
                            <span class="absolute -left-[31px] top-0.5 bg-brand-highlight-600 h-4 w-4 rounded-full border-4 border-slate-200 dark:border-brand-primary-600"></span>
                            <h4 class="text-xs font-bold text-slate-800 dark:text-slate-200 uppercase tracking-wide">3. Laudo Cautelar & Aquisição do Ativo</h4>
                            <p class="text-xs text-slate-600 dark:text-slate-400 mt-1">Auditoria mecânica e documental rigorosa de procedência. Compra do ativo físico. Seu dinheiro vira um veículo real rastreável.</p>
                        </div>
                        <div class="relative">
                            <span class="absolute -left-[31px] top-0.5 bg-emerald-500 h-4 w-4 rounded-full border-4 border-slate-200 dark:border-brand-primary"></span>
                            <h4 class="text-xs font-bold text-slate-800 dark:text-slate-200 uppercase tracking-wide">4. Venda & Distribuição de Dividendos</h4>
                            <p class="text-xs text-slate-600 dark:text-slate-400 mt-1">O veículo é preparado e vendido em menos de 45 dias com margem histórica média de 12%. O lucro retorna e acumula no seu saldo.</p>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- ===== TAB: ASSETS ===== -->
        @if (_activeTab == "assets")
        {
            <div class="flex flex-col gap-6 animate-fade-in">
                <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
                    <div>
                        <h3 class="text-lg font-bold text-slate-900 dark:text-white">Veículos Ativos de Co-Propriedade</h3>
                        <p class="text-xs text-slate-500 dark:text-slate-400">Ativos físicos que lastreiam o seu capital neste exato momento</p>
                    </div>
                    <div class="flex items-center space-x-4 text-xs">
                        <span class="flex items-center space-x-1"><span class="h-2.5 w-2.5 rounded-full bg-amber-500"></span><span class="text-slate-500 dark:text-slate-400">Preparação</span></span>
                        <span class="flex items-center space-x-1"><span class="h-2.5 w-2.5 rounded-full bg-emerald-500"></span><span class="text-slate-500 dark:text-slate-400">À Venda</span></span>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    @foreach (var v in _veiculos)
                    {
                        var isVenda = v.StatusVeiculo == StatusVeiculo.Disponivel;
                        var statusLabel = isVenda ? "À VENDA" : "PREPARAÇÃO";
                        var diasNoPatio = (DateTime.UtcNow - v.DataAlocacao).Days;
                        var percentPatio = Math.Min((double)diasNoPatio / 45.0 * 100.0, 100.0);

                        <div class="bg-white dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 rounded-3xl overflow-hidden flex flex-col shadow-sm dark:shadow-lg">
                            <div class="p-6 bg-gradient-to-br from-brand-primary-600 to-brand-secondary-600 border-b border-slate-200 dark:border-slate-800 flex justify-between items-start">
                                <div>
                                    <span class="@BadgeClass(isVenda)">@statusLabel</span>
                                    <h4 class="text-xl font-bold text-white mt-3">@v.MarcaModelo</h4>
                                    <p class="text-xs text-white/80">Ano/Modelo: @v.AnoFabricacaoModelo</p>
                                </div>
                                <div class="text-right">
                                    <p class="text-[10px] text-white/70 uppercase font-bold tracking-wider">Seu Aporte Alocado</p>
                                    <p class="text-lg font-black text-brand-highlight-600">R$ @v.ValorAlocado.ToString("N2")</p>
                                    <p class="text-[10px] text-white/60">Cota de Participação</p>
                                </div>
                            </div>

                            <div class="p-6 space-y-4 flex-grow">
                                <div class="grid grid-cols-2 gap-4 text-xs">
                                    <div>
                                        <span class="text-slate-500 dark:text-slate-400">Placa do Carro</span>
                                        <p class="font-bold text-slate-900 dark:text-white tracking-widest">@v.Placa</p>
                                    </div>
                                    <div>
                                        <span class="text-slate-500 dark:text-slate-400">KM Rodados</span>
                                        <p class="font-bold text-slate-900 dark:text-white">@v.Km.ToString("N0") km</p>
                                    </div>
                                </div>

                                <div>
                                    <div class="flex justify-between text-xs mb-1.5">
                                        <span class="text-slate-500 dark:text-slate-400 font-medium">Tempo no Pátio (Garage 345)</span>
                                        <span class="@TextColorClass(isVenda) font-bold">@diasNoPatio Dias <span class="text-slate-400 dark:text-slate-500 font-normal">/ Meta &lt; 45d</span></span>
                                    </div>
                                    <div class="w-full bg-slate-200 dark:bg-slate-800 h-2 rounded-full overflow-hidden">
                                        <div class="@ProgressClass(isVenda) h-full rounded-full" style="width: @percentPatio.ToString("F1")%"></div>
                                    </div>
                                </div>

                                <div class="bg-slate-50 dark:bg-slate-900/60 p-3.5 rounded-2xl border border-slate-200 dark:border-slate-800 flex items-center justify-between">
                                    <div class="flex items-center space-x-3">
                                        <div class="h-8 w-8 rounded-lg bg-emerald-500/10 flex items-center justify-center text-emerald-600 dark:text-emerald-400">
                                            <i class="fa-solid fa-file-shield"></i>
                                        </div>
                                        <div>
                                            <p class="text-xs font-bold text-slate-800 dark:text-slate-200">Laudo Cautelar Digital</p>
                                            <p class="text-[10px] text-emerald-600 dark:text-emerald-400 font-semibold"><i class="fa-solid fa-circle-check"></i> 100% Aprovado & Estrutural Limpo</p>
                                        </div>
                                    </div>
                                    <button @onclick='() => OpenLaudo(v.MarcaModelo, v.Placa)' class="text-xs bg-slate-200 dark:bg-slate-800 hover:bg-slate-300 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 font-bold px-3 py-2 rounded-xl border border-slate-300 dark:border-slate-700 transition">
                                        Ver Laudo
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- ===== TAB: SIMULATOR ===== -->
        @if (_activeTab == "simulation")
        {
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 animate-fade-in">
                <div class="lg:col-span-5 bg-white dark:bg-slate-900/30 border border-slate-200 dark:border-slate-800 rounded-3xl p-6 flex flex-col justify-between">
                    <div>
