@code {
    private PatrimonioResponse? _patrimonio;
    private List<VeiculoLastroItemResponse> _veiculos = new();
    private string _activeTab = "overview";
    private bool _erro;
    private string _codigoSCP = "";
    private string? _toastMsg;
    private string? _laudoVeiculo;
    private string? _laudoPlaca;
    private CancellationTokenSource? _toastCts;

    private int _simCapital = 100000;
    private int _simMeses = 36;
    private decimal _simCapitalFinal;
    private decimal _simLucroTotal;
    private decimal _simMultiplo;
    private string _chartPath = "";
    private string _chartFill = "";

    private int PercentualEmCaixa => _patrimonio?.PatrimonioTotal > 0
        ? (int)(_patrimonio.CapitalEmLiquidez / _patrimonio.PatrimonioTotal * 100) : 0;
    private int PercentualAlocado => _patrimonio?.PatrimonioTotal > 0
        ? (int)(_patrimonio.CapitalAlocado / _patrimonio.PatrimonioTotal * 100) : 0;

    protected override async Task OnInitializedAsync()
    {
        var token = await Storage.GetItemAsync<string>("auth_token");
        if (string.IsNullOrEmpty(token))
        {
            Nav.NavigateTo("/login");
            return;
        }

        var investidorIdStr = await Storage.GetItemAsync<string>("auth_investidor_id");
        if (string.IsNullOrEmpty(investidorIdStr))
        {
            Nav.NavigateTo("/login");
            return;
        }

        var investidorId = Guid.Parse(investidorIdStr);
        _codigoSCP = investidorIdStr[..8].ToUpper();

        try
        {
            var patrimonioTask = Api.GetPatrimonioAsync(investidorId);
            var lastroTask = Api.GetRastreabilidadeLastroAsync(investidorId);

            await Task.WhenAll(patrimonioTask, lastroTask);

            _patrimonio = patrimonioTask.Result;
            _veiculos = lastroTask.Result.Veiculos;

            CalcularSimulacao();
        }
        catch (Exception ex)
        {
            if (ex.Message.Contains("401"))
            {
                await Storage.RemoveItemAsync("auth_token");
                await Storage.RemoveItemAsync("auth_investidor_id");
                await Storage.RemoveItemAsync("auth_email");
                await Storage.RemoveItemAsync("auth_role");
                Nav.NavigateTo("/login");
                return;
            }
            _erro = true;
            Console.Error.WriteLine($"Erro ao carregar dashboard: {ex.Message}");
        }
    }

    private void CalcularSimulacao()
    {
        const double taxa = 0.03;
        _simCapitalFinal = (decimal)(_simCapital * Math.Pow(1 + taxa, _simMeses));
        _simLucroTotal = _simCapitalFinal - _simCapital;
        _simMultiplo = _simCapital > 0 ? _simCapitalFinal / _simCapital : 0;

        var points = new List<string>();
        int steps = 10;
        double width = 400, height = 120;

        for (int i = 0; i <= steps; i++)
        {
            double stepMonth = (_simMeses / (double)steps) * i;
            double value = _simCapital * Math.Pow(1 + taxa, stepMonth);
            double x = (width / steps) * i;
            double maxValue = _simCapital * Math.Pow(1 + taxa, 36);
            double normalizedY = height - 10 - ((value / maxValue) * (height - 30));
            points.Add($"{x:F1},{normalizedY:F1}");
        }

        var pathD = $"M {string.Join(" L ", points)}";
        _chartPath = pathD;
        _chartFill = $"{pathD} L 400,120 L 0,120 Z";
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "I";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0][..1].ToUpper();
        return $"{parts[0][..1]}{parts[^1][..1]}".ToUpper();
    }

    private void OpenLaudo(string veiculo, string placa)
    {
        _laudoVeiculo = veiculo;
        _laudoPlaca = placa;
    }

    private void CloseLaudo()
    {
        _laudoVeiculo = null;
        _laudoPlaca = null;
    }

    private async Task Logout()
    {
        await Storage.RemoveItemAsync("auth_token");
        await Storage.RemoveItemAsync("auth_investidor_id");
        await Storage.RemoveItemAsync("auth_email");
        await Storage.RemoveItemAsync("auth_role");
        Nav.NavigateTo("/login");
    }

    private async Task ToggleTheme()
    {
        await Theme.ToggleThemeAsync();
    }

    private string BadgeClass(bool isVenda) => isVenda
        ? "text-[10px] uppercase font-bold tracking-widest px-2.5 py-1 rounded-xl bg-emerald-500/10 text-emerald-400 border border-emerald-500/20"
        : "text-[10px] uppercase font-bold tracking-widest px-2.5 py-1 rounded-xl bg-amber-500/10 text-amber-400 border border-amber-500/20";

    private string TextColorClass(bool isVenda) => isVenda ? "text-emerald-500" : "text-amber-500";

    private string ProgressClass(bool isVenda) => isVenda ? "bg-emerald-500" : "bg-amber-500";

    private async void ShowToast(string message)
    {
        _toastCts?.Cancel();
        _toastCts = new CancellationTokenSource();
        var cts = _toastCts;

        _toastMsg = message;
        StateHasChanged();

        try
        {
            await Task.Delay(3000, cts.Token);
            if (!cts.IsCancellationRequested)
            {
                _toastMsg = null;
                StateHasChanged();
            }
        }
        catch (TaskCanceledException) { }
    }
}
