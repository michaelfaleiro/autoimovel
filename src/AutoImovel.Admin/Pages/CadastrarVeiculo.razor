@page "/veiculos/cadastrar"
@using AutoImovel.Admin.Services
@inject ApiClient Api

<div class="max-w-4xl mx-auto p-6">
    <h1 class="text-2xl font-bold text-brand-primary-600 mb-6">Cadastrar Veículo</h1>

    <div class="bg-brand-white rounded-lg shadow p-6">
        <div class="space-y-4">
            <div class="grid grid-cols-3 gap-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Placa</label>
                    <input @bind="_placa" type="text"
                        class="w-full border border-slate-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-accent-600"
                        placeholder="ABC1D23" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Chassi</label>
                    <input @bind="_chassi" type="text" maxlength="17"
                        class="w-full border border-slate-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-accent-600"
                        placeholder="9BHBG51D0BP012345" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Renavam</label>
                    <input @bind="_renavam" type="text" maxlength="11"
                        class="w-full border border-slate-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-accent-600"
                        placeholder="12345678901" />
                </div>
            </div>

            <div class="grid grid-cols-3 gap-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Marca / Modelo</label>
                    <input @bind="_marcaModelo" type="text"
                        class="w-full border border-slate-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-accent-600"
                        placeholder="Chevrolet Onix" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Ano / Fabricação / Modelo</label>
                    <input @bind="_anoModelo" type="text"
                        class="w-full border border-slate-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-accent-600"
                        placeholder="2022 / 2023 / SELT" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Cor</label>
                    <input @bind="_cor" type="text"
                        class="w-full border border-slate-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-accent-600"
                        placeholder="Prata" />
                </div>
            </div>

            <div class="grid grid-cols-3 gap-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Quilometragem</label>
                    <input @bind="_km" type="number" min="0"
                        class="w-full border border-slate-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-accent-600"
                        placeholder="45000" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Preço Compra (R$)</label>
                    <input @bind="_precoCompra" type="number" step="0.01"
                        class="w-full border border-slate-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-accent-600" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Custos Preparação (R$)</label>
                    <input @bind="_custosPreparacao" type="number" step="0.01"
                        class="w-full border border-slate-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-accent-600" />
                </div>
            </div>

            <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">URL Laudo Cautelar (PDF)</label>
                <input @bind="_urlLaudo" type="url"
                    class="w-full border border-slate-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand-accent-600"
                    placeholder="https://..." />
            </div>

            <button @onclick="SubmitCadastrarVeiculo" disabled="@_isLoading"
                class="bg-brand-primary-600 text-brand-white px-4 py-2 rounded-md hover:bg-brand-primary-700 disabled:opacity-50">
                @(_isLoading ? "Processando..." : "Cadastrar Veículo")
            </button>
        </div>

        @if (!string.IsNullOrEmpty(_mensagem))
        {
            <div class="mt-4 p-3 rounded-md @( _erro ? "bg-red-100 text-red-700" : "bg-emerald-100 text-emerald-700")">
                @_mensagem
            </div>
        }

        @if (_resultado is not null)
        {
            <div class="mt-6 border-t pt-4">
                <h3 class="font-semibold text-slate-800">Veículo Cadastrado:</h3>
                <p class="text-slate-600">Placa: @_resultado.Placa</p>
                <p class="text-slate-600">Modelo: @_resultado.MarcaModelo</p>
                <p class="text-slate-600">Status: @_resultado.Status</p>
                <p class="text-slate-600">Data Compra: @_resultado.DataCompra.ToString("dd/MM/yyyy")</p>
            </div>
        }
    </div>
</div>

@code {
    private string _placa = string.Empty;
    private string _chassi = string.Empty;
    private string _renavam = string.Empty;
    private string _marcaModelo = string.Empty;
    private string _anoModelo = string.Empty;
    private string _cor = string.Empty;
    private int _km;
    private decimal _precoCompra;
    private decimal _custosPreparacao;
    private string _urlLaudo = string.Empty;
    private bool _isLoading;
    private string _mensagem = string.Empty;
    private bool _erro;
    private CadastrarVeiculoResponse? _resultado;

    private async Task SubmitCadastrarVeiculo()
    {
        _isLoading = true;
        _mensagem = string.Empty;
        _erro = false;

        try
        {
            _resultado = await Api.CadastrarVeiculoAsync(new CadastrarVeiculoRequest(
                _placa, _marcaModelo, _anoModelo, _km, _precoCompra, _custosPreparacao, _chassi, _renavam, _cor, _urlLaudo));
            _mensagem = "Veículo cadastrado com sucesso!";
            _erro = false;
        }
        catch (Exception ex)
        {
            _mensagem = $"Erro: {ex.Message}";
            _erro = true;
        }
        finally
        {
            _isLoading = false;
        }
    }
}
