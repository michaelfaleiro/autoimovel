@namespace AutoImovel.UI.Shared.Components.Navigation

<div class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 mb-4">
    @foreach (var (item, idx) in Items.Select((i, idx) => (i, idx)))
    {
        if (idx > 0)
        {
            <span class="text-slate-300 dark:text-slate-600">/</span>
        }
        if (!string.IsNullOrEmpty(item.Href))
        {
            <a href="@item.Href" class="hover:text-sky-600 dark:hover:text-sky-400">@item.Label</a>
        }
        else
        {
            <span class="text-slate-800 dark:text-slate-200 font-medium">@item.Label</span>
        }
    }
</div>

@code {
    [Parameter] public List<BreadcrumbItem> Items { get; set; } = new();

    public class BreadcrumbItem
    {
        public string Label { get; set; } = string.Empty;
        public string? Href { get; set; }
    }
}
