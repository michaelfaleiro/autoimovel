@namespace AutoImovel.UI.Shared.Components.DataDisplay

<div class="@ClassString">
    <div class="flex items-center justify-between">
        <div>
            <p class="@LabelClass">@Label</p>
            <p class="@ValueClass">@FormattedValue</p>
        </div>
        @if (!string.IsNullOrEmpty(Icon))
        {
            <div class="text-3xl opacity-80">@Icon</div>
        }
    </div>
    @if (!string.IsNullOrEmpty(Footer))
    {
        <div class="mt-2 text-xs text-slate-500 border-t pt-2">@Footer</div>
    }
</div>

@code {
    [Parameter] public string Label { get; set; } = string.Empty;
    [Parameter] public decimal Value { get; set; }
    [Parameter] public string? Icon { get; set; }
    [Parameter] public string? Footer { get; set; }
    [Parameter] public string Color { get; set; } = "primary";
    [Parameter] public string Format { get; set; } = "N2";

    private string FormattedValue => $"R$ {Value.ToString(Format)}";

    private string ClassString => Color switch
    {
        "primary" => "bg-white dark:bg-slate-800 rounded-xl shadow-sm border-l-4 border-sky-500 p-5",
        "success" => "bg-white dark:bg-slate-800 rounded-xl shadow-sm border-l-4 border-emerald-500 p-5",
        "warning" => "bg-white dark:bg-slate-800 rounded-xl shadow-sm border-l-4 border-amber-500 p-5",
        "danger" => "bg-white dark:bg-slate-800 rounded-xl shadow-sm border-l-4 border-rose-500 p-5",
        _ => "bg-white dark:bg-slate-800 rounded-xl shadow-sm border-l-4 border-sky-500 p-5"
    };

    private string LabelClass => "text-sm text-slate-500 dark:text-slate-400";

    private string ValueClass => Color switch
    {
        "primary" => "text-2xl font-bold text-sky-700 dark:text-sky-400",
        "success" => "text-2xl font-bold text-emerald-700 dark:text-emerald-400",
        "warning" => "text-2xl font-bold text-amber-700 dark:text-amber-400",
        "danger" => "text-2xl font-bold text-rose-700 dark:text-rose-400",
        _ => "text-2xl font-bold text-sky-700 dark:text-sky-400"
    };
}
