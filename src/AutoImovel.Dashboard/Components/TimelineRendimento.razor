@using AutoImovel.Dashboard.Services

<div class="bg-white rounded-lg shadow p-4">
    <div class="flex items-start gap-4">
        <div class="flex-shrink-0 w-10 h-10 bg-green-100 rounded-full flex items-center justify-center">
            <span class="text-green-700 font-bold text-sm">$</span>
        </div>
        <div class="flex-1">
            <div class="flex justify-between items-start">
                <div>
                    <h4 class="font-semibold text-gray-900">@Rendimento.MarcaModeloVeiculo</h4>
                    <p class="text-sm text-gray-500">Placa: @Rendimento.PlacaVeiculo</p>
                </div>
                <div class="text-right">
                    <p class="text-lg font-bold text-green-700">R$ @Rendimento.LucroLiquidoPago.ToString("N2")</p>
                    <p class="text-xs text-gray-500">@Rendimento.DataFechamento.ToString("dd/MM/yyyy")</p>
                </div>
            </div>

            <div class="mt-3 grid grid-cols-3 gap-2 text-xs">
                <div class="text-center p-2 bg-gray-50 rounded">
                    <p class="text-gray-500">Taxa Gestão</p>
                    <p class="font-medium text-red-600">- R$ @Rendimento.TaxaGestaoRetida.ToString("N2")</p>
                </div>
                <div class="text-center p-2 bg-gray-50 rounded">
                    <p class="text-gray-500">Taxa Infra</p>
                    <p class="font-medium text-red-600">- R$ @Rendimento.TaxaInfraRetida.ToString("N2")</p>
                </div>
                <div class="text-center p-2 bg-gray-50 rounded">
                    <p class="text-gray-500">Performance</p>
                    <p class="font-medium text-red-600">- R$ @Rendimento.TaxaPerformanceRetida.ToString("N2")</p>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public RendimentoItemResponse Rendimento { get; set; } = null!;
}
