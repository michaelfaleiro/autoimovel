@page "/aportes"
@using AutoImovel.Admin.Services
@inject ApiClient Api
@inject NavigationManager Nav

<div class="animate-fade-in">
    <div class="flex items-center justify-between mb-8">
        <div>
            <h2 class="font-plus text-2xl font-black text-brand-primary dark:text-white">Aportes de Capital</h2>
            <p class="text-sm text-slate-500 mt-1">Controle de fluxos de entrada e saldos de liquidez.</p>
        </div>
        <a href="/aportes/novo" class="inline-flex items-center gap-2 px-5 py-2.5 bg-brand-highlight hover:bg-brand-highlightLight text-white text-sm font-bold rounded-xl transition-all shadow-lg shadow-brand-highlight/20">
            <i class="fa-solid fa-money-bill-transfer"></i>
            Registrar Aporte
        </a>
    </div>

    <div class="bg-white dark:bg-slate-900 rounded-2xl shadow-sm border border-slate-200 dark:border-slate-800 overflow-hidden">
        <div class="px-6 py-5 border-b border-slate-200 dark:border-slate-800 flex items-center justify-between flex-wrap gap-4 bg-slate-50/50 dark:bg-slate-800/50">
            <div class="flex items-center gap-3">
                <div class="relative">
                    <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-slate-400">
                        <i class="fa-solid fa-magnifying-glass text-xs"></i>
                    </span>
                    <input @bind="_search" @bind:event="oninput"
                           class="border border-slate-300 dark:border-slate-700 rounded-xl pl-9 pr-3 py-2 text-sm bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-brand-accent w-64 transition-all"
                           placeholder="Buscar por investidor..." />
                </div>
                <select @bind="_statusFilter" @bind:after="ApplyFilters"
                        class="border border-slate-300 dark:border-slate-700 rounded-xl px-3 py-2 text-sm bg-white dark:bg-slate-800 text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-brand-accent transition-all">
                    <option value="">Todos os Status</option>
                    <option value="EmLiquidez">Em Liquidez</option>
                    <option value="Alocado">Alocado</option>
                    <option value="Resgatado">Resgatado</option>
                </select>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-slate-200 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-800/50">
                        <th class="px-6 py-4 text-left font-bold text-brand-primary-600 dark:text-slate-400 uppercase tracking-wider text-[10px]">Investidor</th>
                        <th class="px-6 py-4 text-right font-bold text-brand-primary-600 dark:text-slate-400 uppercase tracking-wider text-[10px]">Valor Original</th>
                        <th class="px-6 py-4 text-right font-bold text-brand-primary-600 dark:text-slate-400 uppercase tracking-wider text-[10px]">Saldo Liquidez</th>
                        <th class="px-6 py-4 text-left font-bold text-brand-primary-600 dark:text-slate-400 uppercase tracking-wider text-[10px]">Status</th>
                        <th class="px-6 py-4 text-left font-bold text-brand-primary-600 dark:text-slate-400 uppercase tracking-wider text-[10px]">Data</th>
                        <th class="px-6 py-4 text-right font-bold text-brand-primary-600 dark:text-slate-400 uppercase tracking-wider text-[10px]">Ações</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                    @if (!_items.Any())
                    {
                        <tr><td colspan="6" class="px-6 py-12 text-center text-slate-400 italic">Nenhum aporte encontrado.</td></tr>
                    }
                    @foreach (var item in _items)
                    {
                        <tr @onclick='() => IrAporte(item.Id)' class="group hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors cursor-pointer">
                            <td class="px-6 py-4">
                                <p class="font-bold text-slate-800 dark:text-slate-200 group-hover:text-brand-primary-600 dark:group-hover:text-brand-gold transition-colors">@item.InvestidorNome</p>
                                <p class="text-[10px] text-slate-400 font-mono mt-0.5">ID: @item.InvestidorId.ToString()[..8]...</p>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <p class="text-sm font-bold text-slate-800 dark:text-slate-200">R$ @item.ValorOriginal.ToString("N2")</p>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <p class="text-sm font-medium text-emerald-600 dark:text-emerald-400">R$ @item.SaldoEmLiquidez.ToString("N2")</p>
                            </td>
                            <td class="px-6 py-4">
                                <span class="px-3 py-1 text-[10px] font-black uppercase rounded-full @(item.Status.ToString() switch { "Alocado" => "bg-blue-500/10 text-blue-600 dark:text-blue-400 border border-blue-500/20", "Resgatado" => "bg-slate-500/10 text-slate-500 dark:text-slate-400 border border-slate-500/20", _ => "bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border border-emerald-500/20" })">
                                    @item.Status.ToString()
                                </span>
                            </td>
                            <td class="px-6 py-4 text-slate-500 dark:text-slate-400 text-xs">@item.DataAporte.ToString("dd/MM/yyyy")</td>
                            <td class="px-6 py-4 text-right">
                                <button class="text-slate-400 hover:text-brand-primary-600 dark:hover:text-brand-gold p-2 transition-colors">
                                    <i class="fa-solid fa-chevron-right text-xs"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="px-6 py-4 border-t border-slate-200 dark:border-slate-800 flex items-center justify-between bg-slate-50/30 dark:bg-slate-900/50">
            <span class="text-xs font-bold text-slate-400 uppercase tracking-widest">Página @_page de @_totalPages</span>
            <div class="flex gap-2">
                <button class="flex items-center gap-1 px-4 py-2 text-xs font-bold uppercase tracking-widest rounded-xl border transition-all @(_page <= 1 ? "text-slate-300 border-slate-200 cursor-not-allowed" : "text-brand-primary-600 dark:text-brand-gold border-brand-primary-600/20 dark:border-slate-800 hover:bg-brand-primary-600 hover:text-brand-white shadow-lg shadow-brand-primary-600/5")"
                        disabled="@(_page <= 1)" @onclick="() => GoToPage(_page - 1)">
                    <i class="fa-solid fa-chevron-left"></i>
                    Anterior
                </button>
                <button class="flex items-center gap-1 px-4 py-2 text-xs font-bold uppercase tracking-widest rounded-xl border transition-all @(_page >= _totalPages ? "text-slate-300 border-slate-200 cursor-not-allowed" : "text-brand-primary-600 dark:text-brand-gold border-brand-primary-600/20 dark:border-slate-800 hover:bg-brand-primary-600 hover:text-brand-white shadow-lg shadow-brand-primary-600/5")"
                        disabled="@(_page >= _totalPages)" @onclick="() => GoToPage(_page + 1)">
                    Próxima
                    <i class="fa-solid fa-chevron-right"></i>
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private List<AporteItem> _items = new();
    private int _page = 1;
    private int _totalPages = 1;
    private string _search = string.Empty;
    private string _statusFilter = string.Empty;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        var result = await Api.GetAportesAsync(_page, 20, string.IsNullOrEmpty(_search) ? null : _search, string.IsNullOrEmpty(_statusFilter) ? null : _statusFilter);
        _items = result.Items;
        _totalPages = result.TotalPages > 0 ? result.TotalPages : 1;
    }

    private async Task ApplyFilters()
    {
        _page = 1;
        await LoadData();
    }

    private async Task GoToPage(int page)
    {
        if (page < 1 || page > _totalPages) return;
        _page = page;
        await LoadData();
    }

    private void IrAporte(Guid id) => Nav.NavigateTo($"/aportes/{id}");
}
