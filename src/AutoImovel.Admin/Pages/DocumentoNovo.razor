@page "/documentos/novo"
@using AutoImovel.Admin.Services
@using AutoImovel.Shared.Domain
@inject ApiClient Api
@inject NavigationManager Nav

<div class="animate-fade-in">
    <div class="mb-6">
        <a href="/documentos" class="text-sm text-brand-primary-600 dark:text-brand-accent-300 hover:underline font-bold inline-flex items-center gap-2">
            <i class="fa-solid fa-arrow-left"></i> Voltar para Documentos
        </a>
    </div>

    <div class="bg-brand-white dark:bg-black border border-slate-200 dark:border-brand-primary-800 rounded-2xl shadow-sm overflow-hidden max-w-3xl">
        <div class="px-6 py-5 border-b border-slate-200 dark:border-brand-primary-800/20 bg-slate-50/50 dark:bg-brand-primary-900/50">
            <h3 class="font-plus text-lg font-bold text-brand-primary-600 dark:text-brand-white">Novo Documento</h3>
            <p class="text-xs text-slate-500 mt-1">Adicione um novo documento vinculado a um veículo ou investidor.</p>
        </div>

        <div class="p-6 space-y-5">
            @if (_loading)
            {
                <div class="flex flex-col items-center justify-center py-12">
                    <div class="animate-spin inline-block w-8 h-8 border-4 border-brand-accent-600 border-t-transparent rounded-full mb-4"></div>
                    <div class="text-slate-500 font-medium text-sm">Carregando dados...</div>
                </div>
            }
            else
            {
                @if (!string.IsNullOrEmpty(_erroMsg))
                {
                    <div class="bg-rose-500/10 border border-rose-500/20 text-rose-500 p-3.5 rounded-xl text-xs font-semibold flex items-center gap-2 mb-6">
                        <i class="fa-solid fa-circle-exclamation text-lg"></i>
                        @_erroMsg
                    </div>
                }

                <div>
                    <label class="block text-xs font-black uppercase tracking-widest text-slate-500 mb-2">Nome do Documento</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 pl-3.5 flex items-center text-slate-400">
                            <i class="fa-solid fa-file-signature"></i>
                        </span>
                        <input @bind="_nome"
                                    class="w-full bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 rounded-xl pl-10 pr-4 py-3 text-sm text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-brand-accent-600 transition-all"
                               placeholder="Ex: Laudo Cautelar do HB20" />
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    <div>
                        <label class="block text-xs font-black uppercase tracking-widest text-slate-500 mb-2">Tipo de Documento</label>
                        <select @bind="_tipo"
                                class="w-full bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 rounded-xl px-4 py-3 text-sm text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-brand-accent-600 transition-all">
                            <option value="Laudo">Laudo Cautelar</option>
                            <option value="Contrato">Contrato SCP</option>
                            <option value="Relatorio">Relatório Operacional</option>
                            <option value="Fiscal">Documento Fiscal</option>
                            <option value="Outro">Outro</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-black uppercase tracking-widest text-slate-500 mb-2">URL do Arquivo</label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 pl-3.5 flex items-center text-slate-400">
                                <i class="fa-solid fa-link"></i>
                            </span>
                            <input @bind="_url" type="url"
                                   class="w-full bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 rounded-xl pl-10 pr-4 py-3 text-sm text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-brand-accent-600 transition-all"
                                   placeholder="https://drive.google.com/..." />
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-5 pt-4 border-t border-slate-200 dark:border-slate-800">
                    <div>
                        <label class="block text-xs font-black uppercase tracking-widest text-brand-primary-600 dark:text-brand-accent-300 mb-2 flex items-center gap-2">
                            <i class="fa-solid fa-car-side"></i> Vínculo: Veículo (Opcional)
                        </label>
                        <select @bind="_veiculoId"
                                class="w-full bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 rounded-xl px-4 py-3 text-sm text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-brand-accent-600 transition-all">
                            <option value="">Selecione um veículo...</option>
                            @foreach (var v in _veiculos)
                            {
                                <option value="@v.Id">@v.Placa - @v.MarcaModelo</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-black uppercase tracking-widest text-brand-primary-600 dark:text-brand-accent-300 mb-2 flex items-center gap-2">
                            <i class="fa-solid fa-user-tie"></i> Vínculo: Investidor (Opcional)
                        </label>
                        <select @bind="_investidorId"
                                class="w-full bg-slate-50 dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 rounded-xl px-4 py-3 text-sm text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-brand-accent-600 transition-all">
                            <option value="">Selecione um investidor...</option>
                            @foreach (var i in _investidores)
                            {
                                <option value="@i.Id">@i.NomeCompleto</option>
                            }
                        </select>
                    </div>
                </div>
            }
        </div>
        
        @if (!_loading)
        {
            <div class="px-6 py-4 border-t border-slate-200 dark:border-brand-primary-800/20 bg-slate-50/50 dark:bg-brand-primary-900/50 flex justify-end">
                <button @onclick="SalvarDocumento"
                        disabled="@_saving"
                        class="px-6 py-2.5 bg-brand-primary-600 hover:bg-brand-secondary-600 text-brand-white font-bold rounded-xl transition-all shadow-lg shadow-brand-primary-600/20 disabled:opacity-50 flex items-center gap-2">
                    @if (_saving)
                    {
                        <i class="fa-solid fa-circle-notch animate-spin"></i>
                        <span>Salvando...</span>
                    }
                    else
                    {
                        <i class="fa-solid fa-upload"></i>
                        <span>Salvar Documento</span>
                    }
                </button>
            </div>
        }
    </div>
</div>

@code {
    private string _nome = string.Empty;
    private string _tipo = "Laudo";
    private VeiculoId? _veiculoId = null;
    private InvestidorId? _investidorId = null;
    private string _url = string.Empty;
    private bool _loading = true;
    private bool _saving = false;
    private string _erroMsg = string.Empty;
    private List<SelectVeiculo> _veiculos = new();
    private List<SelectInvestidor> _investidores = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadLookupData();
    }

    private async Task LoadLookupData()
    {
        _loading = true;
        try
        {
            _veiculos = await Api.GetVeiculosSelectAsync();
            _investidores = await Api.GetInvestidoresSelectAsync();
        }
        catch (Exception ex)
        {
            _erroMsg = "Falha ao carregar opções de vínculo.";
            Console.Error.WriteLine(ex);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SalvarDocumento()
    {
        _erroMsg = string.Empty;

        if (string.IsNullOrWhiteSpace(_nome))
        {
            _erroMsg = "O nome do documento é obrigatório.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_url))
        {
            _erroMsg = "A URL do documento é obrigatória.";
            return;
        }

        _saving = true;
        try
        {
            var request = new DocumentoRequest(
                _nome.Trim(),
                _tipo.Trim(),
                _url.Trim(),
                _veiculoId,
                _investidorId
            );

            await Api.CreateDocumentoAsync(request);
            Nav.NavigateTo("/documentos");
        }
        catch (Exception ex)
        {
            _erroMsg = ex.Message;
            Console.Error.WriteLine($"Erro ao salvar documento: {ex.Message}");
        }
        finally
        {
            _saving = false;
        }
    }
}
